{
	"name": "dexbooru-web",
	"version": "0.0.1",
	"author": "Tanish Shah",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "dotenv -e .env -o -- vite dev",
		"build": "prisma generate --schema ./prisma/schema && vite build && pnpm build:workers",
		"build:workers": "node build-workers.mjs",
		"preview": "dotenv -e .env -o -- vite preview",
		"run-build": "dotenv -e .env -o -- node build/index.js",
		"setup:localstack": "dotenv -e .env -o -- bash ./scripts/init-localstack.sh",
		"preinstall": "npx only-allow pnpm",
		"postinstall": "svelte-kit sync && prisma generate",
		"dbpredeploy": "dotenv -e .env -o -- prisma migrate deploy",
		"postdeploy": "bash ./scripts/post-deploy.sh",
		"dbseed": "dotenv -e .env -o -- prisma db push --force-reset && prisma db seed",
		"dbmigrate": "dotenv -e .env -o -- prisma migrate dev",
		"dbreset": "dotenv -e .env -o -- prisma migrate reset",
		"dbpush": "dotenv -e .env -o -- prisma db push",
		"dbgenerate": "dotenv -e .env -o -- prisma generate",
		"dbstudio": "dotenv -e .env -o -- prisma studio",
		"datamigration:create": "dotenv -e .env -o -- tsx scripts/dataMigrations/createDataMigration.ts",
		"datamigration:run": "dotenv -e .env -o -- tsx scripts/dataMigrations/runDataMigrations.ts",
		"datamigration:run-one": "dotenv -e .env -o -- tsx scripts/dataMigrations/runSingleDataMigration.ts",
		"appconfig:sync": "dotenv -e .env -o -- tsx scripts/syncApplicationConfiguration.ts",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage.enabled --coverage.reporter=html --coverage.reporter=text",
		"test:coverage:ci": "vitest run --coverage.enabled --coverage.reporter=json-summary --coverage.reporter=json",
		"lint": "prettier --check . && eslint .",
		"lint:fix": "prettier --write . && eslint . --fix",
		"format": "prettier --write 'src/**/*.{ts,svelte}' 'scripts/**/*.ts'",
		"prepare": "husky && svelte-kit sync"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.6",
		"@eslint/js": "^10.0.1",
		"@faker-js/faker": "^10.5.0",
		"@flowbite-svelte-plugins/chart": "^0.2.4",
		"@sveltejs/adapter-node": "^5.5.7",
		"@sveltejs/kit": "^2.70.0",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@tailwindcss/vite": "^4.3.3",
		"@types/bcryptjs": "^3.0.0",
		"@types/html-to-text": "^9.0.4",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/markdown-it": "^14.1.2",
		"@types/markdown-it-emoji": "^3.0.1",
		"@types/minimist": "^1.2.5",
		"@types/node": "^24.13.3",
		"@types/nodemailer": "^8.0.1",
		"@types/nprogress": "^0.2.3",
		"@types/qrcode": "^1.5.6",
		"@types/sanitize-html": "^2.16.1",
		"@types/turndown": "^5.0.6",
		"@typescript-eslint/eslint-plugin": "^8.64.0",
		"@typescript-eslint/parser": "^8.64.0",
		"@vitest/coverage-v8": "^4.1.10",
		"clsx": "^2.1.1",
		"csv-reader": "^1.0.12",
		"dotenv": "^17.4.2",
		"dotenv-cli": "^11.0.0",
		"eslint": "^10.7.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"flowbite": "^4.0.2",
		"flowbite-svelte": "^1.33.1",
		"flowbite-svelte-icons": "^3.1.0",
		"globals": "^17.7.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.1.0",
		"minimist": "^1.2.8",
		"prettier": "^3.9.5",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.1",
		"prisma": "^7.8.0",
		"svelte": "^5.56.6",
		"svelte-check": "^4.7.3",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.3",
		"tslib": "^2.8.1",
		"tsx": "^4.23.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.64.0",
		"vite": "^8.1.5",
		"vitest": "^4.1.10"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1090.0",
		"@aws-sdk/client-sqs": "^3.1090.0",
		"@humanspeak/svelte-virtual-list": "^0.5.12",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@zerodevx/svelte-toast": "^0.9.6",
		"base32-encode": "^2.0.0",
		"bcryptjs": "^3.0.3",
		"cookie": "^1.1.1",
		"html-to-text": "^10.0.0",
		"jdenticon": "^3.3.0",
		"jsonwebtoken": "^9.0.3",
		"markdown-it": "^14.3.0",
		"markdown-it-emoji": "^3.0.0",
		"nodemailer": "^9.0.3",
		"nprogress": "^0.2.0",
		"otpauth": "^9.5.1",
		"qrcode": "^1.5.4",
		"rabbitmq-client": "^5.0.8",
		"redis": "^6.1.0",
		"sanitize-html": "^2.17.6",
		"sharp": "^0.35.3",
		"turndown": "^7.2.4",
		"winston": "^3.19.0",
		"yaml": "^2.9.0",
		"zod": "^4.4.3"
	},
	"peerDependencies": {
		"svelte": "^3.55.1 || ^4.0.0 || ^5.0.0 || ^5.41.0"
	},
	"lint-staged": {
		"src/**/*.{ts,svelte}": [
			"prettier --write"
		],
		"scripts/**/*.ts": [
			"prettier --write"
		],
		"*.{js,jsx,ts,tsx,svelte}": [
			"eslint --fix"
		]
	},
	"engines": {
		"node": "24.x"
	},
	"packageManager": "pnpm@11.15.0",
	"exports": {
		".": {
			"svelte": "./dist/index.js"
		}
	}
}
